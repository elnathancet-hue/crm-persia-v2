{
  "name": "@persia/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./database": {
      "types": "./src/database.ts",
      "default": "./src/database.ts"
    },
    "./whatsapp": {
      "types": "./src/whatsapp.ts",
      "default": "./src/whatsapp.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    },
    "./providers/*": {
      "types": "./src/providers/*.ts",
      "default": "./src/providers/*.ts"
    },
    "./template-parser": {
      "types": "./src/template-parser.ts",
      "default": "./src/template-parser.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
