# EditorConfig — https://editorconfig.org
# Garante UTF-8 sem BOM em todos os arquivos de codigo.
# Previne double-encoding de caracteres especiais (ex: emojis, · U+00B7).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,html,md,yaml,yml}]
indent_style = space
indent_size = 2
